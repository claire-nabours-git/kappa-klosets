rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in users can access anything
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles: any signed-in user can read; only owner can write
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // Listings: anyone can read; authenticated users can create;
    // only the seller can update or delete their own listing
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.sellerUid;

      // Q&A comments — anyone can read, only signed-in users can write
      match /messages/{msgId} {
        allow read: if true;
        allow create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.uid;
      }
    }

    // Offers: buyer or seller can read/write their own offers
    match /offers/{offerId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.buyerUid ||
        request.auth.uid == resource.data.sellerUid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.buyerUid ||
        request.auth.uid == resource.data.sellerUid
      );
    }

    // DMs: only participants can read or write
    match /dms/{convId} {
      allow read, update: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;

      // Messages inside a DM thread
      match /messages/{msgId} {
        allow read, create: if isAuth();
        allow delete: if isAuth() && request.auth.uid == resource.data.senderUid;
      }
    }
  }
}
